## 5. 元件測試規範

```ts
// *.component.spec.ts
describe('UserCardComponent', () => {
  let fixture: ComponentFixture<UserCardComponent>;
  let component: UserCardComponent;

  beforeEach(async () => {
    await TestBed.configureTestingModule({
      imports: [UserCardComponent],  // Standalone component
    }).compileComponents();

    fixture = TestBed.createComponent(UserCardComponent);
    component = fixture.componentInstance;
    fixture.detectChanges();
  });

  it('should render the label input', () => {
    fixture.componentRef.setInput('label', 'Test User');
    fixture.detectChanges();
    const el = fixture.nativeElement.querySelector('.user-card__title');
    expect(el?.textContent).toContain('Test User');
  });

  it('should show spinner when loading', () => {
    // 觸發 loadingState = 'loading'
    component['loadingState'].set('loading');
    fixture.detectChanges();
    expect(fixture.nativeElement.querySelector('app-spinner')).toBeTruthy();
  });
});
```
