## 3. Angular Signals 規範

### 3.1 本機狀態管理

```ts
export class CartComponent {
  // ✅ Writable signal：命名無 $ 後綴
  protected readonly items = signal<CartItem[]>([]);
  protected readonly discount = signal(0);

  // ✅ Computed signal：衍生值永遠用 computed()
  protected readonly subtotal = computed(() =>
    this.items().reduce((sum, item) => sum + item.price * item.qty, 0),
  );
  protected readonly total = computed(() =>
    this.subtotal() * (1 - this.discount() / 100),
  );

  // ✅ 更新：使用 update() 或 set()，禁止 mutate()
  addItem(item: CartItem): void {
    this.items.update(list => [...list, item]);
  }

  removeItem(id: string): void {
    this.items.update(list => list.filter(i => i.id !== id));
  }

  applyDiscount(pct: number): void {
    this.discount.set(Math.min(100, Math.max(0, pct)));
  }
}
```

### 3.2 Effect 使用限制

```ts
// ✅ effect() 適用場景：同步到外部系統（localStorage、analytics、DOM API）
export class ThemeComponent {
  private readonly theme = inject(ThemeService).current;  // Signal

  constructor() {
    // effect 在 injection context 中呼叫
    effect(() => {
      document.documentElement.setAttribute('data-theme', this.theme());
    });
  }
}

// ❌ 禁止：在 effect 中修改其他 signal（形成循環依賴）
effect(() => {
  this.count.set(this.items().length);  // 危險！可能造成無限迴圈
});
// ✅ 改用 computed()
protected readonly count = computed(() => this.items().length);
```

### 3.3 Service 中的 Signals

```ts
@Injectable({ providedIn: 'root' })
export class NotificationService {
  // 私有 writable signal
  private readonly _notifications = signal<Notification[]>([]);

  // 公開 readonly signal（消費方不能直接修改）
  readonly notifications: Signal<Notification[]> = this._notifications.asReadonly();

  // 計數衍生
  readonly unreadCount = computed(() =>
    this._notifications().filter(n => !n.read).length,
  );

  push(notification: Notification): void {
    this._notifications.update(list => [notification, ...list]);
  }

  markAllRead(): void {
    this._notifications.update(list =>
      list.map(n => ({ ...n, read: true })),
    );
  }
}
```

